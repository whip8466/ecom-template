generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  firstName     String         @map("first_name") @db.VarChar(120)
  lastName      String         @map("last_name") @db.VarChar(120)
  name          String?
  email         String         @unique
  phone         String?
  passwordHash  String         @map("password_hash")
  role          String         @default("CUSTOMER") @db.VarChar(30)
  isActive      Boolean        @default(true) @map("is_active")
  addresses     Address[]
  orders         Order[]
  customerNotes  CustomerNote[]
  wishlistItems  WishlistItem[]
  productReviews ProductReview[]
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

model CustomerNote {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("customer_notes")
}

model Address {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String   @map("full_name")
  phone        String
  addressLine1 String   @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String
  state        String
  postalCode   String   @map("postal_code")
  country      String
  isDefault    Boolean  @default(false) @map("is_default")
  orders       Order[]
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("addresses")
}

model Category {
  id        Int        @id @default(autoincrement())
  parentId  Int?       @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryTree")
  name      String
  slug      String     @unique
  iconUrl   String?    @map("icon_url")
  products  Product[]
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([parentId])
  @@map("categories")
}

model Vendor {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("vendors")
}

model Collection {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("collections")
}

model Tag {
  id           Int          @id @default(autoincrement())
  name         String
  slug         String       @unique
  productTags  ProductTag[]
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("tags")
}

model ProductTag {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId     Int      @map("tag_id")
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@map("product_tags")
}

model ProductOptionType {
  id        Int                 @id @default(autoincrement())
  name      String
  slug      String              @unique
  values    ProductOptionValue[]
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("product_option_types")
}

model ProductOptionValue {
  id              Int              @id @default(autoincrement())
  optionTypeId    Int              @map("option_type_id")
  optionType      ProductOptionType @relation(fields: [optionTypeId], references: [id], onDelete: Cascade)
  value           String
  label           String
  sortOrder       Int              @default(0) @map("sort_order")
  variantOptions  ProductVariantOptionValue[]
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("product_option_values")
}

model ProductVariant {
  id          Int                         @id @default(autoincrement())
  productId   Int                         @map("product_id")
  product     Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String?                     @unique
  priceCents  Int?                        @map("price_cents")
  stock       Int                         @default(0)
  optionValues ProductVariantOptionValue[]
  createdAt   DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("product_variants")
}

model ProductVariantOptionValue {
  id             Int               @id @default(autoincrement())
  variantId      Int               @map("variant_id")
  variant        ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValueId  Int               @map("option_value_id")
  optionValue    ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@map("product_variant_option_values")
}

model Product {
  id              Int            @id @default(autoincrement())
  name            String
  slug            String         @unique
  status          String         @default("DRAFT") @db.VarChar(20)
  shortDescription String?       @map("short_description")
  description     String?
  priceCents      Int            @map("price_cents")
  salePriceCents  Int?           @map("sale_price_cents")
  stock           Int            @default(0)
  /// Units ordered / in shipment but not yet received at warehouse.
  stockInTransit  Int            @default(0) @map("stock_in_transit")
  lastRestockedAt DateTime?      @map("last_restocked_at") @db.Timestamptz(6)
  /// Cumulative units received into inventory (increments on restock; seed on create).
  totalStockLifetime Int       @default(0) @map("total_stock_lifetime")
  fulfillmentType String?        @map("fulfillment_type") @db.VarChar(32)
  externalProductIdType String?  @map("external_product_id_type") @db.VarChar(20)
  externalProductId String?      @map("external_product_id") @db.VarChar(120)
  categoryId      Int?           @map("category_id")
  category        Category?      @relation(fields: [categoryId], references: [id])
  vendorId        Int?           @map("vendor_id")
  vendor          Vendor?       @relation(fields: [vendorId], references: [id])
  collectionId    Int?           @map("collection_id")
  collection      Collection?    @relation(fields: [collectionId], references: [id])
  productTags     ProductTag[]
  images          ProductImage[]
  availableColors ProductColor[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
  wishlistItems   WishlistItem[]
  productReviews  ProductReview[]
  dealOfDaySlot    DealOfDayProduct?
  dealOfDayHistory DealOfDayHistory[]
  publishedAt     DateTime?      @map("published_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("products")
}

/// Curated home “Deal of the Day” strip (up to four rows, ordered by sortOrder).
model DealOfDayProduct {
  id              Int       @id @default(autoincrement())
  sortOrder       Int       @map("sort_order")
  productId       Int       @unique @map("product_id")
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  dealPriceCents  Int       @map("deal_price_cents")
  durationMinutes Int       @default(60) @map("duration_minutes")
  activatedAt     DateTime? @map("activated_at") @db.Timestamptz(6)
  endsAt          DateTime? @map("ends_at") @db.Timestamptz(6)

  @@unique([sortOrder])
  @@map("deal_of_day_products")
}

/// Archived deal runs (expired, stopped early, or removed from slots while live).
model DealOfDayHistory {
  id              Int      @id @default(autoincrement())
  productId       Int      @map("product_id")
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  dealPriceCents  Int      @map("deal_price_cents")
  durationMinutes Int      @map("duration_minutes")
  activatedAt     DateTime @map("activated_at") @db.Timestamptz(6)
  endsAt          DateTime @map("ends_at") @db.Timestamptz(6)
  endedAt         DateTime @map("ended_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([productId])
  @@index([endedAt])
  @@map("deal_of_day_history")
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int      @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}

model HomeBannerSlide {
  id             Int      @id @default(autoincrement())
  sortOrder      Int      @default(0) @map("sort_order")
  priceLine      String   @map("price_line") @db.VarChar(500)
  title          String   @db.VarChar(500)
  offerPrefix    String   @default("") @map("offer_prefix") @db.VarChar(500)
  offerHighlight String   @map("offer_highlight") @db.VarChar(200)
  offerSuffix    String   @default("") @map("offer_suffix") @db.VarChar(500)
  imageUrl       String   @map("image_url") @db.VarChar(2000)
  imageAlt       String   @default("") @map("image_alt") @db.VarChar(500)
  ctaHref        String   @default("/shop") @map("cta_href") @db.VarChar(500)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("home_banner_slides")
}

model PromoBanner {
  id           Int      @id @default(autoincrement())
  sortOrder    Int      @default(0) @map("sort_order")
  eyebrowLabel String   @map("eyebrow_label") @db.VarChar(200)
  title        String   @db.VarChar(500)
  subtitle     String?  @db.VarChar(500)
  imageUrl     String?  @map("image_url") @db.VarChar(2000)
  imageAlt     String   @default("") @map("image_alt") @db.VarChar(500)
  ctaLabel     String   @default("Shop Now") @map("cta_label") @db.VarChar(120)
  ctaHref      String   @default("/shop") @map("cta_href") @db.VarChar(500)
  styleVariant String   @default("neutral") @map("style_variant") @db.VarChar(20)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("promo_banners")
}

model NewsletterSubscription {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(320)
  source    String   @default("footer") @db.VarChar(2048)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("newsletter_subscriptions")
}

/** Singleton row (id = 1): storefront contact page + footer copy. */
model ContactSettings {
  id             Int      @id @default(1)
  headline       String   @default("Keep In Touch with Us") @db.VarChar(200)
  brandName      String   @default("Dhidi") @map("brand_name") @db.VarChar(120)
  footerTagline  String   @default("Curated fashion, beauty, and home decor for modern living. Quality you can trust, style that lasts.") @map("footer_tagline") @db.Text
  primaryEmail   String   @map("primary_email") @db.VarChar(320)
  supportEmail   String   @map("support_email") @db.VarChar(320)
  phone          String   @db.VarChar(80)
  addressLine    String   @map("address_line") @db.VarChar(500)
  mapEmbedUrl    String?  @map("map_embed_url") @db.Text
  facebookUrl    String?  @map("facebook_url") @db.VarChar(500)
  instagramUrl   String?  @map("instagram_url") @db.VarChar(500)
  pinterestUrl   String?  @map("pinterest_url") @db.VarChar(500)
  twitterUrl     String?  @map("twitter_url") @db.VarChar(500)
  youtubeUrl     String?  @map("youtube_url") @db.VarChar(500)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("contact_settings")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(200)
  email     String   @db.VarChar(320)
  subject   String   @db.VarChar(500)
  body      String   @db.Text
  saveInfo  Boolean  @default(false) @map("save_info")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("contact_messages")
}

model BlogCategory {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(200)
  slug      String     @unique @db.VarChar(200)
  posts     BlogPost[]
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("blog_categories")
}

model BlogPost {
  id              Int           @id @default(autoincrement())
  title           String        @db.VarChar(500)
  slug            String        @unique @db.VarChar(200)
  excerpt         String?       @db.VarChar(1000)
  body            String        @db.Text
  coverImageUrl   String?       @map("cover_image_url") @db.VarChar(2000)
  publishedAt     DateTime?     @map("published_at") @db.Timestamptz(6)
  blogCategoryId  Int?          @map("blog_category_id")
  blogCategory    BlogCategory? @relation(fields: [blogCategoryId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([publishedAt])
  @@index([blogCategoryId])
  @@map("blog_posts")
}

model ProductImage {
  id       Int     @id @default(autoincrement())
  productId Int    @map("product_id")
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl String  @map("image_url")

  @@map("product_images")
}

model ProductColor {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName String  @map("color_name")
  colorCode String  @map("color_code")
  stock     Int?

  @@map("product_colors")
}

model Order {
  id               Int           @id @default(autoincrement())
  userId           Int           @map("user_id")
  user             User          @relation(fields: [userId], references: [id])
  addressId        Int           @map("address_id")
  address          Address       @relation(fields: [addressId], references: [id])
  totalAmountCents Int           @map("total_amount_cents")
  status           String        @default("PENDING") @db.VarChar(30)
  paymentStatus    String        @default("PENDING") @map("payment_status") @db.VarChar(30)
  items            OrderItem[]
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("orders")
}

model OrderItem {
  id                       Int     @id @default(autoincrement())
  orderId                  Int     @map("order_id")
  order                    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId                Int     @map("product_id")
  product                  Product @relation(fields: [productId], references: [id])
  productNameSnapshot      String  @map("product_name_snapshot")
  productPriceSnapshotCents Int    @map("product_price_snapshot_cents")
  colorName                String? @map("color_name")
  quantity                 Int
  subtotalCents            Int     @map("subtotal_cents")
  review                   ProductReview?

  @@map("order_items")
}

/// One review per purchased order line (verified buyer). Tied to order_item_id.
model ProductReview {
  id          Int       @id @default(autoincrement())
  orderItemId Int       @unique @map("order_item_id")
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating      Int
  body        String    @db.Text
  /// PENDING = awaiting moderation; APPROVED = visible on product page.
  status      String    @default("PENDING") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([productId])
  @@index([userId])
  @@index([status])
  @@map("product_reviews")
}

/// Storefront static content (About, Privacy, Terms) — edited in admin.
model SitePage {
  id        Int      @id @default(autoincrement())
  slug      String   @unique @db.VarChar(64)
  title     String   @db.VarChar(500)
  body      String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_pages")
}

/// FAQ category (sidebar group on /faq).
model FaqCategory {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(200)
  slug      String    @unique @db.VarChar(180)
  iconKey   String    @default("document") @map("icon_key") @db.VarChar(32)
  sortOrder Int       @default(0) @map("sort_order")
  items     FaqItem[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("faq_categories")
}

model FaqItem {
  id         Int         @id @default(autoincrement())
  categoryId Int         @map("category_id")
  category   FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  question   String      @db.VarChar(500)
  answer     String      @db.Text
  sortOrder  Int         @default(0) @map("sort_order")
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([categoryId])
  @@map("faq_items")
}
