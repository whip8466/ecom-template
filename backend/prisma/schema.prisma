generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  firstName    String    @map("first_name") @db.VarChar(120)
  lastName     String    @map("last_name") @db.VarChar(120)
  name         String?
  email        String    @unique
  phone        String?
  passwordHash String    @map("password_hash")
  role         String    @default("CUSTOMER") @db.VarChar(30)
  isActive     Boolean   @default(true) @map("is_active")
  addresses    Address[]
  orders       Order[]
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

model Address {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String   @map("full_name")
  phone        String
  addressLine1 String   @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String
  state        String
  postalCode   String   @map("postal_code")
  country      String
  isDefault    Boolean  @default(false) @map("is_default")
  orders       Order[]
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("addresses")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("categories")
}

model Vendor {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("vendors")
}

model Collection {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("collections")
}

model Tag {
  id           Int          @id @default(autoincrement())
  name         String
  slug         String       @unique
  productTags  ProductTag[]
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("tags")
}

model ProductTag {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId     Int      @map("tag_id")
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@map("product_tags")
}

model ProductOptionType {
  id        Int                 @id @default(autoincrement())
  name      String
  slug      String              @unique
  values    ProductOptionValue[]
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("product_option_types")
}

model ProductOptionValue {
  id              Int              @id @default(autoincrement())
  optionTypeId    Int              @map("option_type_id")
  optionType      ProductOptionType @relation(fields: [optionTypeId], references: [id], onDelete: Cascade)
  value           String
  label           String
  sortOrder       Int              @default(0) @map("sort_order")
  variantOptions  ProductVariantOptionValue[]
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("product_option_values")
}

model ProductVariant {
  id          Int                         @id @default(autoincrement())
  productId   Int                         @map("product_id")
  product     Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String?                     @unique
  priceCents  Int?                        @map("price_cents")
  stock       Int                         @default(0)
  optionValues ProductVariantOptionValue[]
  createdAt   DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("product_variants")
}

model ProductVariantOptionValue {
  id             Int               @id @default(autoincrement())
  variantId      Int               @map("variant_id")
  variant        ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValueId  Int               @map("option_value_id")
  optionValue    ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@map("product_variant_option_values")
}

model Product {
  id              Int            @id @default(autoincrement())
  name            String
  slug            String         @unique
  status          String         @default("DRAFT") @db.VarChar(20)
  shortDescription String?       @map("short_description")
  description     String?
  priceCents      Int            @map("price_cents")
  salePriceCents  Int?           @map("sale_price_cents")
  stock           Int            @default(0)
  fulfillmentType String?        @map("fulfillment_type") @db.VarChar(32)
  externalProductIdType String?  @map("external_product_id_type") @db.VarChar(20)
  externalProductId String?      @map("external_product_id") @db.VarChar(120)
  categoryId      Int?           @map("category_id")
  category        Category?      @relation(fields: [categoryId], references: [id])
  vendorId        Int?           @map("vendor_id")
  vendor          Vendor?       @relation(fields: [vendorId], references: [id])
  collectionId    Int?           @map("collection_id")
  collection      Collection?    @relation(fields: [collectionId], references: [id])
  productTags     ProductTag[]
  images          ProductImage[]
  availableColors ProductColor[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
  publishedAt     DateTime?      @map("published_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("products")
}

model ProductImage {
  id       Int     @id @default(autoincrement())
  productId Int    @map("product_id")
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl String  @map("image_url")

  @@map("product_images")
}

model ProductColor {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName String  @map("color_name")
  colorCode String  @map("color_code")
  stock     Int?

  @@map("product_colors")
}

model Order {
  id               Int           @id @default(autoincrement())
  userId           Int           @map("user_id")
  user             User          @relation(fields: [userId], references: [id])
  addressId        Int           @map("address_id")
  address          Address       @relation(fields: [addressId], references: [id])
  totalAmountCents Int           @map("total_amount_cents")
  status           String        @default("PENDING") @db.VarChar(30)
  paymentStatus    String        @default("PENDING") @map("payment_status") @db.VarChar(30)
  items            OrderItem[]
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("orders")
}

model OrderItem {
  id                       Int     @id @default(autoincrement())
  orderId                  Int     @map("order_id")
  order                    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId                Int     @map("product_id")
  product                  Product @relation(fields: [productId], references: [id])
  productNameSnapshot      String  @map("product_name_snapshot")
  productPriceSnapshotCents Int    @map("product_price_snapshot_cents")
  colorName                String? @map("color_name")
  quantity                 Int
  subtotalCents            Int     @map("subtotal_cents")

  @@map("order_items")
}
