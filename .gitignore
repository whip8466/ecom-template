# Monorepo ignore rules (frontend + backend)

# dependencies
**/node_modules/
/frontend/node_modules/
/backend/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# build outputs / caches
**/.next/
**/out/
**/dist/
**/build/
**/coverage/
**/.turbo/
**/.cache/
**/.parcel-cache/
**/.eslintcache
**/*.tsbuildinfo
next-env.d.ts

# API user uploads (brand logos, etc.)
/backend/uploads/

# logs / runtime temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
**/*.pid
tmp/
temp/

# environment files (keep examples)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
!**/.env.example

# deployment / platform
**/.vercel/

# OS / certs / misc
.DS_Store
*.pem
.frontend-git-backup/
